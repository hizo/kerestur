# Build-time public variables (read via import.meta.env, baked into the page).
# Copy to `.env` for local dev; set in Cloudflare Pages as a plain variable.
# Runtime secrets (Resend, Turnstile secret, recipient) live in .dev.vars — see
# .dev.vars.example.

# Cloudflare Turnstile — public site key for the widget on /kontakt.
# If unset, the form renders without the Turnstile widget (still works).
# Local dummy that always passes: 1x00000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
