---
import { Image } from 'astro:assets';
import BackLink from '@/components/BackLink.astro';
import Base from '@/layouts/Base.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import heroImg from '../../specs/photos/1.jpg';
import mladeImg from '../../specs/photos/mlade-2.jpg';
import pstrosyImg from '../../specs/photos/3.jpg';
import vajceImg from '../../specs/photos/vajce-presvietene.png';
import winterImg from '../../specs/photos/pstros-1.jpg';
import maleImg from '../../specs/photos/pstros-2.jpg';
import flockImg from '../../specs/photos/pstros-3.jpg';
import youngImg from '../../specs/photos/pstros-4.jpg';
import closeupImg from '../../specs/photos/pstros-5.jpg';

const lead =
  'Najväčší žijúci vták na Zemi. Behá rýchlosťou až 70 km/h a v zajatí sa dožíva šesťdesiatky. U nás žije v prirodzených podmienkach a je srdcom farmy.';

const gallery = [
  {
    src: pstrosyImg,
    alt: 'Dvojica dospelých pštrosov pri západe slnka',
    caption: 'Dospelé pštrosy. Tridsať kusov, každý so svojím menom.',
  },
  {
    src: mladeImg,
    alt: 'Pštrosie mláďa zblízka, prvé dni života na farme',
    caption: 'Mláďatá. Liahnu sa od marca do júna, prvé dni v teplej liahni.',
  },
  {
    src: vajceImg,
    alt: 'Pštrosie vajce presvietené zboku, žiarivo červené a oranžové',
    caption: 'Pštrosie vajce. 1,5 kg, stačí na omeletu pre celú rodinu.',
  },
];
---

<Base title="Pštros africký — Farma Kerestúr" description={lead}>
  <SiteHeader />

  <main>
    <article>
      <header class="grid lg:grid-cols-[3fr_2fr] bg-surface text-ink">
        <figure
          class="relative aspect-[4/3] lg:aspect-auto lg:min-h-[520px] overflow-hidden"
        >
          <Image
            src={heroImg}
            alt="Pštros kráča pri západe slnka po výbehu Farmy Kerestúr"
            widths={[600, 900, 1400, 1800]}
            sizes="(min-width: 1024px) 60vw, 100vw"
            loading="eager"
            fetchpriority="high"
            class="absolute inset-0 h-full w-full object-cover object-[50%_30%]"
          />
        </figure>

        <div
          class="flex flex-col justify-center gap-6 px-8 py-14 lg:px-14 lg:py-20 max-w-2xl"
        >
          <p
            class="font-body text-xs uppercase tracking-[0.22em] text-ink-muted leading-tight"
          >
            Pštrosia farma Kerestúr
          </p>
          <h1
            class="font-display font-normal text-balance text-[clamp(2.5rem,5vw,4.25rem)] leading-[1.02] text-ink"
          >
            Pštros africký
          </h1>
          <p class="font-body text-lg leading-relaxed text-ink-muted">
            {lead}
          </p>
        </div>
      </header>

      <div class="bg-surface-muted py-16 lg:py-24">
        <div class="mx-auto max-w-3xl px-6 prose">
          <h2>Pštros africký dvojprstý</h2>
          <p><em>Struthio camelus</em></p>
          <p><strong>Pôvod:</strong> Afrika</p>
          <p>
            Pštros dvojprstý alebo pštros africký je vták z čeľade pštrosovité.
            Je to najväčší žijúci vták na Zemi.
          </p>
          <p>
            Pštros má dlhý neoperený krk, malú hlavu, mohutné telo a dlhé svalnaté
            nohy. Je priťažký na lietanie, ale zato rýchlo a vytrvalo behá —
            rýchlosťou 70 km/h vydrží bežať až tridsať minút.
          </p>
          <p>
            Pštrosy vytvárajú kŕdle zložené z oboch pohlaví, iba zriedkavo sa
            vyskytujú jednotlivo.
          </p>

          <h2>Charakteristika</h2>
          <ul>
            <li>nelietavý vták, vyniká stehenným svalstvom — bežec</li>
            <li>najväčší žijúci vták na Zemi</li>
            <li>rýchlosť až 70 km/h</li>
            <li>v zajatí sa dožíva až šesťdesiatich rokov</li>
          </ul>

          <h2>Význam chovu</h2>
          <p>
            <strong>Mäso</strong> — výživné, diétne, mäkké mäso vysokej kvality
            s nízkym obsahom tuku a cholesterolu.
          </p>
          <p>
            <strong>Vajcia</strong> — jedlé, jedno vajce zasýti približne osem
            až desať ľudí.
          </p>
        </div>
      </div>

      <section class="py-16 lg:py-24 bg-surface">
        <div class="mx-auto max-w-6xl px-6">
          <header class="mb-10 max-w-2xl">
            <p
              class="font-body text-xs uppercase tracking-[0.22em] text-ink-muted mb-3"
            >
              V troch obrázkoch
            </p>
            <h2
              class="font-display text-balance text-3xl lg:text-4xl text-ink leading-[1.1]"
            >
              Dospelý pštros, mláďatá, vajcia.
            </h2>
          </header>
          <div class="grid gap-6 sm:grid-cols-3">
            {
              gallery.map((g) => (
                <figure class="flex flex-col gap-3">
                  <div class="relative aspect-[4/5] overflow-hidden rounded-lg">
                    <Image
                      src={g.src}
                      alt={g.alt}
                      widths={[400, 600, 900]}
                      sizes="(min-width: 640px) 30vw, 90vw"
                      loading="lazy"
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  </div>
                  <figcaption class="font-body text-base text-ink-muted leading-relaxed">
                    {g.caption}
                  </figcaption>
                </figure>
              ))
            }
          </div>
        </div>
      </section>

      <section class="py-16 lg:py-24 bg-surface-muted">
        <div class="mx-auto max-w-6xl px-6">
          <header class="mb-10 max-w-2xl">
            <p
              class="font-body text-xs uppercase tracking-[0.22em] text-ink-muted mb-3"
            >
              Z výbehu
            </p>
            <h2
              class="font-display text-balance text-3xl lg:text-4xl text-ink leading-[1.1]"
            >
              Kŕdeľ počas celého roka.
            </h2>
            <p class="font-body text-lg leading-relaxed text-ink-muted mt-4">
              V snehu aj pri západe slnka — pštrosy u nás žijú vonku a podľa
              ročného obdobia mení výbeh aj svoju náladu.
            </p>
          </header>

          <div class="grid gap-6 lg:grid-cols-2">
            <figure class="flex flex-col gap-3">
              <div class="relative aspect-[3/4] overflow-hidden rounded-lg">
                <Image
                  src={closeupImg}
                  alt="Detail hlavy a krku pštrosa pri zlatom západe slnka"
                  widths={[500, 750, 1100]}
                  sizes="(min-width: 1024px) 45vw, 90vw"
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover"
                />
              </div>
              <figcaption class="font-body text-base text-ink-muted leading-relaxed">
                Zblízka. Zvedavý pohľad pri večernom svetle.
              </figcaption>
            </figure>
            <figure class="flex flex-col gap-3">
              <div class="relative aspect-[3/4] overflow-hidden rounded-lg">
                <Image
                  src={maleImg}
                  alt="Dospelý čierny pštrosí samec na výbehu pri západe slnka"
                  widths={[500, 750, 1100]}
                  sizes="(min-width: 1024px) 45vw, 90vw"
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover"
                />
              </div>
              <figcaption class="font-body text-base text-ink-muted leading-relaxed">
                Samec v čiernom perí, oranžová obloha za chrbtom.
              </figcaption>
            </figure>
          </div>

          <figure class="mt-6 flex flex-col gap-3">
            <div class="relative aspect-[16/9] overflow-hidden rounded-lg">
              <Image
                src={flockImg}
                alt="Celý kŕdeľ pštrosov na rozľahlom výbehu pod zamračenou oblohou"
                widths={[700, 1100, 1600]}
                sizes="(min-width: 1024px) 70vw, 90vw"
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover"
              />
            </div>
            <figcaption class="font-body text-base text-ink-muted leading-relaxed">
              Celý kŕdeľ pohromade — tridsať kusov na výbehu.
            </figcaption>
          </figure>

          <div class="mt-6 grid gap-6 lg:grid-cols-2">
            <figure class="flex flex-col gap-3">
              <div class="relative aspect-[4/5] overflow-hidden rounded-lg">
                <Image
                  src={winterImg}
                  alt="Kŕdeľ pštrosov v zasneženom výbehu počas zimy"
                  widths={[500, 750, 1100]}
                  sizes="(min-width: 1024px) 45vw, 90vw"
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover object-[50%_40%]"
                />
              </div>
              <figcaption class="font-body text-base text-ink-muted leading-relaxed">
                Aj v zime sú vonku — sneh im neprekáža.
              </figcaption>
            </figure>
            <figure class="flex flex-col gap-3">
              <div class="relative aspect-[4/5] overflow-hidden rounded-lg">
                <Image
                  src={youngImg}
                  alt="Skupina dorastajúcich pštrosov v letnej tráve"
                  widths={[500, 750, 1100]}
                  sizes="(min-width: 1024px) 45vw, 90vw"
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover"
                />
              </div>
              <figcaption class="font-body text-base text-ink-muted leading-relaxed">
                Dorastajúce mláďatá v letnej tráve.
              </figcaption>
            </figure>
          </div>
        </div>
      </section>

      <BackLink />
    </article>
  </main>

  <SiteFooter />
</Base>
