---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Farma Kerestúr — rodinná pštrosia farma 30 minút od Bratislavy"
  description="Šťastný pštros, dobrý pštros. Návštevy, vajcia, mäso, príbeh."
>
  <main class="mx-auto max-w-2xl px-6 py-16">
    <h1 class="font-display text-4xl mb-4 text-ink">Farma Kerestúr</h1>
    <p class="font-body text-ink-muted mb-6">
      Scaffold v príprave. Reálny web prichádza po locku brand direction.
    </p>
    <a
      href="/mockup"
      class="inline-flex items-center gap-2 rounded-full bg-ink px-5 py-2.5 font-body text-sm text-surface hover:opacity-90"
    >
      Pozrieť brand mockupy
      <span aria-hidden="true">→</span>
    </a>
  </main>
</Base>
