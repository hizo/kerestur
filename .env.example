# Resend API key for contact form (set in Cloudflare Pages env, never commit real value)
RESEND_API_KEY=

# Cloudflare Turnstile keys (sitekey is public, secret is server-only)
PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET_KEY=

# Email addresses for form notifications
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=
