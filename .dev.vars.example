# Runtime secrets for the contact form (read by the Cloudflare Function).
# Copy to `.dev.vars` for local `pnpm dev`, and set the same in Cloudflare Pages
# (Settings → Environment variables, as Secrets).
# NOTE: the PUBLIC_ Turnstile site key does NOT go here — it's a build-time var
# read via import.meta.env, so it lives in `.env` (see .env.example).

# Resend API key. To send WITHOUT verifying a domain, pair it with
# CONTACT_FROM=onboarding@resend.dev and CONTACT_TO=<your Resend account e-mail>.
RESEND_API_KEY=

# Cloudflare Turnstile — secret key, used server-side to verify the token.
# Local dummy that always passes: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=

# Optional — override the default recipient/sender from src/pages/api/contact.ts.
# CONTACT_TO=farma@kerestur.sk
# CONTACT_FROM=Farma Kerestúr <web@farmakerestur.sk>
