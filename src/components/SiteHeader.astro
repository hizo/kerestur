---
import { Image } from 'astro:assets';
import logo from '../../specs/existing-logo.png';
import SocialLinks from './SocialLinks.astro';

const nav = [
  { href: '/pstros', label: 'Pštros' },
  { href: '/kuchyna', label: 'Kuchyňa' },
  { href: '/o-nas', label: 'O nás' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-surface border-b border-border transition-transform duration-300 will-change-transform motion-reduce:transition-none data-[hidden=true]:-translate-y-full"
>
  <div
    class="mx-auto max-w-6xl px-4 sm:px-6 py-4 flex items-center justify-between gap-4"
  >
    <a href="/" class="flex items-center gap-3 group shrink-0">
      <Image
        src={logo}
        alt="Farma Kerestúr"
        width={48}
        height={48}
        class="rounded-full shrink-0"
      />
      <span
        class="hidden sm:inline font-display text-lg text-ink group-hover:text-brand transition"
      >
        Farma Kerestúr
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-7" aria-label="Hlavná navigácia">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="font-body text-base text-ink-muted hover:text-ink transition"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4 shrink-0">
      <SocialLinks class="text-ink-muted" iconClass="size-5" />

      <a
        href="tel:+421905323828"
        class="inline-flex items-center gap-2 font-body text-sm sm:text-base font-medium text-ink hover:text-brand transition whitespace-nowrap"
        aria-label="Zavolať na farmu"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-4 sm:size-5 shrink-0"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
          />
        </svg>
        +421 905 323 828
      </a>

      <details id="mobile-menu" class="group lg:hidden">
        <summary
          class="-mr-2 flex size-11 cursor-pointer list-none items-center justify-center rounded-md text-ink transition hover:text-brand [&::-webkit-details-marker]:hidden"
          aria-label="Menu"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-6 group-open:hidden"
          >
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden size-6 group-open:block"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </summary>

        <div class="absolute inset-x-0 top-full border-b border-border bg-surface shadow-lg">
          <nav
            class="mx-auto flex max-w-6xl flex-col px-4 sm:px-6 py-2"
            aria-label="Mobilná navigácia"
          >
            {
              nav.map((item) => (
                <a
                  href={item.href}
                  class="border-b border-border/60 py-3.5 font-body text-lg text-ink transition last:border-0 hover:text-brand"
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const menu = document.getElementById('mobile-menu') as HTMLDetailsElement | null;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // The mobile menu is a native <details> that works without JS. This only
  // adds niceties: close on link click, on Escape, and when widening to desktop.
  if (menu) {
    menu.addEventListener('click', (e) => {
      if (e.target instanceof Element && e.target.closest('a')) menu.open = false;
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.open) {
        menu.open = false;
        menu.querySelector('summary')?.focus();
      }
    });
    window.matchMedia('(min-width: 1024px)').addEventListener('change', (e) => {
      if (e.matches) menu.open = false;
    });
  }

  // Pre-rendered header is sticky via CSS; this adds the auto-hide behaviour
  // (hide on scroll down, reveal on scroll up). Skipped for prefers-reduced-motion,
  // and never hides while the mobile menu is open.
  if (header && !reduceMotion) {
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = Math.max(window.scrollY, 0);
      if (Math.abs(y - lastY) > 6) {
        const goingDown = y > lastY;
        header.dataset.hidden = String(!menu?.open && goingDown && y > header.offsetHeight);
        lastY = y;
      }
      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true },
    );
  }
</script>
